@model IEnumerable<Category>

<style>
    /* ===== CATEGORY COMPONENT ===== */
    .cat-filter-wrap { font-size: .88rem; }

    /* Category list inside sidebar */
    .cat-filter-wrap .cat-list li { border-bottom: 1px solid #f0f0f0; }
    .cat-filter-wrap .cat-list li:last-child { border-bottom: none; }

    .cat-filter-wrap .cat-list a {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .55rem .3rem;
        color: #555;
        text-decoration: none;
        border-radius: 6px;
        transition: color .2s, padding-left .2s;
    }

    .cat-filter-wrap .cat-list a:hover,
    .cat-filter-wrap .cat-list a.active {
        color: var(--primary, #FE980F);
        padding-left: .4rem;
    }

    .cat-filter-wrap .cat-list .cat-arrow {
        color: #ccc;
        font-size: .75rem;
        transition: color .2s, transform .2s;
    }

    .cat-filter-wrap .cat-list a:hover .cat-arrow { color: var(--primary, #FE980F); transform: translateX(2px); }

    /* Price filter card */
    .price-filter-card {
        background: #fff;
        border-radius: var(--radius, 14px);
        overflow: hidden;
        box-shadow: var(--shadow-sm, 0 2px 12px rgba(0,0,0,.07));
        margin-top: 1rem;
    }

    .price-filter-header {
        background: var(--dark, #16213e);
        color: #fff;
        padding: .85rem 1.2rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        font-weight: 700;
        font-size: .92rem;
    }

    .price-filter-header i { color: var(--primary, #FE980F); }

    .price-filter-body { padding: 1rem 1.2rem; }

    /* Price inputs */
    .price-row {
        display: flex;
        gap: .5rem;
        margin-bottom: .9rem;
    }

    .price-input-wrap {
        flex: 1;
        position: relative;
    }

    .price-input-wrap label {
        font-size: .72rem;
        font-weight: 700;
        color: #888;
        text-transform: uppercase;
        letter-spacing: .08em;
        display: block;
        margin-bottom: .25rem;
    }

    .price-input-wrap input {
        width: 100%;
        border: 1.5px solid #e5e5e5;
        border-radius: 8px;
        padding: .45rem .7rem;
        font-size: .82rem;
        font-weight: 600;
        color: var(--dark, #16213e);
        transition: border-color .2s;
    }

    .price-input-wrap input:focus {
        border-color: var(--primary, #FE980F);
        outline: none;
        box-shadow: 0 0 0 3px rgba(254,152,15,.12);
    }

    /* Sort radio */
    .sort-label-top {
        font-size: .78rem;
        font-weight: 700;
        color: #666;
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: .5rem;
        display: block;
    }

    .sort-options { display: flex; gap: .4rem; margin-bottom: .9rem; }

    .sort-option {
        flex: 1;
        position: relative;
    }

    .sort-option input[type="radio"] { display: none; }

    .sort-option label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
        padding: .45rem;
        border: 1.5px solid #e5e5e5;
        border-radius: 8px;
        font-size: .8rem;
        font-weight: 600;
        color: #666;
        cursor: pointer;
        transition: border-color .2s, background .2s, color .2s;
        text-align: center;
    }

    .sort-option input[type="radio"]:checked + label {
        border-color: var(--primary, #FE980F);
        background: rgba(254,152,15,.08);
        color: var(--primary, #FE980F);
    }

    /* Apply button */
    .btn-filter-apply {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        width: 100%;
        background: var(--primary, #FE980F);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .6rem;
        font-size: .85rem;
        font-weight: 700;
        cursor: pointer;
        transition: background .25s, transform .2s;
    }

    .btn-filter-apply:hover {
        background: var(--primary-dark, #e07d0b);
        transform: translateY(-1px);
    }
</style>

<div class="cat-filter-wrap">
    <!-- Categories -->
    <ul class="cat-list list-unstyled mb-0">
        @foreach (var c in Model)
        {
            <li>
                <a asp-action="Index" asp-controller="Product"
                   asp-route-cid="@c.CategoryId"
                   asp-route-search="@ViewBag.Search"
                   asp-route-minPrice="@ViewBag.MinPrice"
                   asp-route-maxPrice="@ViewBag.MaxPrice"
                   asp-route-sort="@ViewBag.Sort"
                   class="@(ViewBag.Cid != null && (int)ViewBag.Cid == c.CategoryId ? "active" : "")">
                    <i class="feather-chevron-right cat-arrow"></i>
                    @c.CategoryName
                </a>
            </li>
        }
    </ul>
</div>

<!-- Price Filter -->
<div class="price-filter-card">
    <div class="price-filter-header">
        <i class="feather-sliders"></i>
        <span>Lọc theo giá</span>
    </div>
    <div class="price-filter-body">
        <form asp-action="Index" asp-controller="Product">
            <input type="hidden" name="cid"    value="@ViewBag.Cid" />
            <input type="hidden" name="search" value="@ViewBag.Search" />

            <div class="price-row">
                <div class="price-input-wrap">
                    <label>Từ (₫)</label>
                    <input type="number" name="minPrice" value="@ViewBag.MinPrice" min="0" placeholder="0" />
                </div>
                <div class="price-input-wrap">
                    <label>Đến (₫)</label>
                    <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" min="0" placeholder="∞" />
                </div>
            </div>

            <span class="sort-label-top">Sắp xếp</span>
            <div class="sort-options">
                <div class="sort-option">
                    <input type="radio" id="sortAsc" name="sort" value="asc"
                           @(ViewBag.Sort == "asc" || ViewBag.Sort == "" || ViewBag.Sort == null ? "checked" : "") />
                    <label for="sortAsc"><i class="feather-trending-up" style="font-size:.85rem;"></i> Thấp → cao</label>
                </div>
                <div class="sort-option">
                    <input type="radio" id="sortDesc" name="sort" value="desc"
                           @(ViewBag.Sort == "desc" ? "checked" : "") />
                    <label for="sortDesc"><i class="feather-trending-down" style="font-size:.85rem;"></i> Cao → thấp</label>
                </div>
            </div>

            <button type="submit" class="btn-filter-apply">
                <i class="feather-filter"></i> Áp dụng
            </button>
        </form>
    </div>
</div>
