<style>
    /* ===== FEATURED PRODUCTS SECTION ===== */
    .featured-section {
        padding: 5rem 0 4rem;
        background: #fafbfc;
    }

    .section-label {
        display: inline-block;
        background: rgba(254,152,15,.12);
        color: var(--primary, #FE980F);
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        padding: .3rem 1rem;
        border-radius: 20px;
        margin-bottom: .6rem;
    }

    .section-title-main {
        font-size: clamp(1.5rem, 3vw, 2.1rem);
        font-weight: 800;
        color: var(--dark, #16213e);
        margin-bottom: .4rem;
    }

    .section-title-main span { color: var(--primary, #FE980F); }

    .section-divider {
        width: 48px;
        height: 4px;
        background: var(--primary, #FE980F);
        border-radius: 2px;
        margin: .6rem auto 0;
    }

    /* Product Card */
    .prod-card {
        background: #fff;
        border-radius: var(--radius, 14px);
        overflow: hidden;
        box-shadow: var(--shadow-sm, 0 2px 12px rgba(0,0,0,.07));
        transition: transform .3s, box-shadow .3s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .prod-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-md, 0 8px 30px rgba(0,0,0,.12));
    }

    .prod-img-wrap {
        position: relative;
        overflow: hidden;
        height: 300px;
        flex-shrink: 0;
    }

    .prod-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .5s ease;
    }

    .prod-card:hover .prod-img-wrap img { transform: scale(1.07); }

    /* Hover overlay */
    .prod-overlay {
        position: absolute;
        inset: 0;
        background: rgba(22,33,62,.55);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .6rem;
        opacity: 0;
        transition: opacity .3s;
    }

    .prod-card:hover .prod-overlay { opacity: 1; }

    .prod-overlay-btn {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #fff;
        color: var(--dark, #16213e);
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        text-decoration: none;
        transition: background .2s, color .2s, transform .2s;
    }

    .prod-overlay-btn:hover {
        background: var(--primary, #FE980F);
        color: #fff;
        transform: scale(1.1);
    }

    /* Badge */
    .prod-badge {
        position: absolute;
        top: .75rem;
        left: .75rem;
        background: var(--primary, #FE980F);
        color: #fff;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        padding: .25rem .65rem;
        border-radius: 20px;
        z-index: 2;
    }

    /* Card body */
    .prod-card-body {
        padding: 1rem 1.1rem 1.2rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .prod-name {
        font-size: .95rem;
        font-weight: 700;
        color: var(--dark, #16213e);
        margin-bottom: .35rem;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color .2s;
    }

    .prod-name:hover { color: var(--primary, #FE980F); }

    .prod-price {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--primary, #FE980F);
        margin-bottom: .75rem;
    }

    .prod-actions { margin-top: auto; display: flex; gap: .5rem; flex-wrap: wrap; }

    .btn-prod-primary {
        flex: 1;
        background: var(--primary, #FE980F);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .55rem .8rem;
        font-size: .82rem;
        font-weight: 700;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
        transition: background .25s, transform .2s;
        cursor: pointer;
    }

    .btn-prod-primary:hover {
        background: var(--primary-dark, #e07d0b);
        transform: translateY(-1px);
        color: #fff;
    }

    .btn-prod-outline {
        background: #fff;
        color: var(--dark, #16213e);
        border: 1.5px solid #e5e5e5;
        border-radius: 8px;
        padding: .55rem .8rem;
        font-size: .82rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: .3rem;
        transition: border-color .2s, color .2s;
        cursor: pointer;
    }

    .btn-prod-outline:hover {
        border-color: var(--primary, #FE980F);
        color: var(--primary, #FE980F);
    }

    /* Owl carousel dots for this section */
    .featured-carousel .owl-dots {
        margin-top: 1.5rem;
        text-align: center;
    }

    .featured-carousel .owl-dot span {
        width: 8px;
        height: 8px;
        background: #ddd !important;
        border-radius: 50px;
        margin: 0 3px;
        transition: width .3s, background .3s !important;
        display: inline-block;
    }

    .featured-carousel .owl-dot.active span {
        width: 24px;
        background: var(--primary, #FE980F) !important;
    }

    /* View all button */
    .btn-view-all {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        background: var(--dark, #16213e);
        color: #fff;
        padding: .75rem 2rem;
        border-radius: 30px;
        font-weight: 700;
        font-size: .92rem;
        text-decoration: none;
        transition: background .25s, transform .2s, box-shadow .25s;
        margin-top: 2.5rem;
    }

    .btn-view-all:hover {
        background: var(--primary, #FE980F);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(254,152,15,.3);
        color: #fff;
    }

    /* Contact modal */
    .contact-modal-wrap {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.6);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px);
    }

    .contact-modal-wrap.active { display: flex; }

    .contact-modal-box {
        background: #fff;
        border-radius: var(--radius, 14px);
        padding: 2rem;
        width: 100%;
        max-width: 480px;
        max-height: 90vh;
        overflow-y: auto;
        position: relative;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
        animation: modalPop .3s ease;
    }

    @@keyframes modalPop {
        from { opacity: 0; transform: scale(.92) translateY(20px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .contact-modal-close {
        position: absolute;
        top: 1rem; right: 1rem;
        width: 32px; height: 32px;
        border-radius: 50%;
        background: #f3f3f3;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 1.1rem;
        color: #555;
        transition: background .2s;
    }

    .contact-modal-close:hover { background: var(--primary, #FE980F); color: #fff; }
</style>

<section class="featured-section" id="featured">
    <div class="container">
        <div class="text-center mb-4" data-aos="fade-down">
            <span class="section-label">Nổi bật</span>
            <h2 class="section-title-main">Sản phẩm <span>tiêu biểu</span></h2>
            <div class="section-divider mx-auto"></div>
        </div>

        <div class="featured-carousel owl-carousel owl-theme" data-aos="fade-up">
            @{
                List<Product> items = ViewBag.LatestItems;
                foreach (var item in items)
                {
                    <div class="prod-card-wrap px-2">
                        <div class="prod-card">
                            <div class="prod-img-wrap">
                                <span class="prod-badge">Mới</span>
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId">
                                    <img src="@item.Image" alt="@item.ProductName" loading="lazy" />
                                </a>
                                <div class="prod-overlay">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId"
                                       class="prod-overlay-btn" title="Xem chi tiết">
                                        <i class="feather-eye"></i>
                                    </a>
                                    <button type="button" class="prod-overlay-btn"
                                            onclick="openContactModal(@item.ProductId, '@item.ProductName')"
                                            title="Liên hệ">
                                        <i class="feather-message-circle"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="prod-card-body">
                                <a class="prod-name"
                                   asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId">
                                    @item.ProductName
                                </a>
                                <div class="prod-price">@Convert.ToDecimal(item.UnitPrice).ToString("N0") ₫</div>
                                <div class="prod-actions">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId"
                                       class="btn-prod-primary">
                                        <i class="feather-shopping-cart"></i> Đặt ngay
                                    </a>
                                    <button type="button" class="btn-prod-outline"
                                            onclick="openContactModal(@item.ProductId, '@item.ProductName')">
                                        <i class="feather-send"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="text-center" data-aos="fade-up">
            <a asp-controller="Product" asp-action="Index" class="btn-view-all">
                Xem tất cả sản phẩm <i class="feather-arrow-right"></i>
            </a>
        </div>
    </div>
</section>

<!-- Contact Modal -->
<div id="contactModal" class="contact-modal-wrap">
    <div class="contact-modal-box">
        <button class="contact-modal-close" onclick="closeContactModal()">
            <i class="feather-x"></i>
        </button>
        <h4 id="modalTitle" class="fw-bold mb-4" style="color:var(--dark,#16213e);padding-right:2rem;"></h4>
        <form asp-controller="Email" asp-action="Submit" method="post" enctype="multipart/form-data">
            <input type="hidden" name="ProductId" id="modalProductId" />
            <div class="mb-3">
                <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                <input type="text" name="FullName" class="form-control" placeholder="Nguyễn Văn A" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>
                <input type="tel" name="Phone" class="form-control" placeholder="0912 345 678" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                <input type="email" name="Email" class="form-control" placeholder="email@example.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Số lượng cần tư vấn <span class="text-danger">*</span></label>
                <input type="number" name="Quantity" class="form-control" placeholder="50" min="1" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">File thiết kế</label>
                <input type="file" name="File" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Lời nhắn</label>
                <textarea name="Note" class="form-control" rows="3"
                          placeholder="Nội dung thiết kế (càng chi tiết càng tốt)"></textarea>
            </div>
            <button type="submit" class="btn-prod-primary w-100" style="border-radius:10px;padding:.75rem;">
                <i class="feather-send me-2"></i> Gửi yêu cầu
            </button>
        </form>
    </div>
</div>

<script>
    // Carousel
    $(document).ready(function () {
        $(".featured-carousel").owlCarousel({
            loop: true,
            margin: 0,
            autoplay: true,
            autoplayTimeout: 4500,
            autoplayHoverPause: true,
            smartSpeed: 700,
            dots: true,
            nav: false,
            responsive: {
                0:    { items: 1 },
                576:  { items: 2 },
                992:  { items: 3 },
                1200: { items: 4 }
            }
        });
    });

    // Modal
    function openContactModal(productId, productName) {
        document.getElementById("modalTitle").textContent = "Liên hệ: " + productName;
        document.getElementById("modalProductId").value = productId;
        document.getElementById("contactModal").classList.add("active");
        document.body.style.overflow = "hidden";
    }

    function closeContactModal() {
        document.getElementById("contactModal").classList.remove("active");
        document.body.style.overflow = "";
    }

    document.getElementById("contactModal").addEventListener("click", function (e) {
        if (e.target === this) closeContactModal();
    });
</script>
